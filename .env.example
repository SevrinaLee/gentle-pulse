# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── AI tagging & suggestions ─────────────────────────────────────────────────
# Optional. Without it, check-ins are tagged AND suggestion copy is generated by
# rule-based heuristics/templates (source: "heuristic-fallback"). Add a real key
# any time to switch both to GPT-4o — no code change needed. If a GPT-4o call
# fails, the app falls back to the heuristic/template automatically.
OPENAI_API_KEY=

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
