# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── AI: tagging, suggestions & voice input ───────────────────────────────────
# Optional, but powers three things once set (no code change, just redeploy):
#   1. Check-in tagging      → GPT-4o (else rule-based heuristic)
#   2. Suggestion copy       → GPT-4o (else hand-written templates)
#   3. Voice input (Whisper) → the mic button appears on the check-in form and
#      /api/transcribe activates; hidden/disabled while this is unset.
# Tagging & suggestions fall back automatically if a GPT-4o call fails.
OPENAI_API_KEY=

# ── Weekly digest email (Resend) ─────────────────────────────────────────────
# Optional. When set, the "Weekly digest" opt-in appears on /account and the
# Sunday cron (vercel.json → /api/cron/weekly-digest) actually sends. Without
# it, the toggle is hidden and the cron reports "skipped". Sending to arbitrary
# addresses needs a domain verified in Resend; set DIGEST_FROM_EMAIL to a sender
# on that domain (default onboarding@resend.dev only reaches your own address).
RESEND_API_KEY=
DIGEST_FROM_EMAIL=Gentle Pulse <onboarding@resend.dev>

# Shared secret the Vercel Cron uses to authorize the digest endpoint. Set this
# to a long random string in the Vercel env; the cron refuses to run without it.
CRON_SECRET=

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
