# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── AI tagging ───────────────────────────────────────────────────────────────
# Optional. Without it, check-ins are tagged by a rule-based heuristic instead
# (source: "heuristic-fallback"). Add a real key any time to switch to GPT-4o.
OPENAI_API_KEY=

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
